<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" /> <!-- For sensors -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" /> <!-- Web View -->
    <uses-permission android:name="android.permission.INTERNET" /> <!-- Sensitive permissions -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Android_6_month"
        tools:targetApi="31">
        <activity
            android:name=".Maps.LocationActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>
        <activity
            android:name=".AndroidSDK.SensorActivity"
            android:exported="false" />
        <activity
            android:name=".IntentActivity"
            android:exported="false" />
        <activity
            android:name=".AndroidSDK.ReceiverActivity"
            android:exported="false" />
        <activity
            android:name=".MLKit.OCRActivity"
            android:exported="false" />
        <activity
            android:name=".MVVM.View.MVVMActivity"
            android:exported="false" />
        <activity
            android:name=".API.GetUserDataActivity"
            android:exported="true">

        </activity>
        <activity
            android:name=".Appwrite.ImageUploadActivity"
            android:exported="true" />
        <activity
            android:name=".Firebase.RecyclerDBActivity"
            android:exported="true" />
        <activity
            android:name=".Firebase.RealDBActivity"
            android:exported="true" />
        <activity
            android:name=".Firebase.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".Permissions.PermissionsActivity"
            android:exported="false" />
        <activity
            android:name=".WebView.WebActivity"
            android:exported="true" />
        <activity
            android:name=".RoomDatabase.RoomActivity"
            android:exported="true" />
        <activity
            android:name=".TestActivity"
            android:exported="false" /> <!-- <activity -->
        <!-- android:name=".Drawer.DrawerActivity" -->
        <!-- android:exported="true" -->
        <!-- android:label="@string/title_activity_drawer" -->
        <!-- android:theme="@style/Theme.Android_6_month.NoActionBar" /> -->
        <activity
            android:name=".Splash.SplashActivity"
            android:exported="true" />
        <activity
            android:name=".Recycler_View.RecyclerViewActivity"
            android:exported="true" />
        <activity
            android:name=".BottomNavigation.BottomNavigationActivity"
            android:exported="true"
            android:label="@string/title_activity_bottom_navigation" />
        <activity
            android:name=".ConstraintLayout.ConstraintActivity"
            android:exported="true" />
        <activity
            android:name=".RelativeLayout.RelativeLayoutActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true" />

        <service
            android:name=".FCM.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <receiver
            android:name=".AndroidSDK.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notifications_black_24dp" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="fcm_default_channel" />

        <service
            android:name=".AndroidSDK.MyForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>